<mxfile host="app.diagrams.net">
  <diagram name="Azure Architecture">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="internet" value="Internet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="420" y="20" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="frontdoor" value="Azure Front Door + WAF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="370" y="120" width="300" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="web" value="App Service (Web)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="180" y="280" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="api" value="App Service (API Container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="580" y="280" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="storage" value="Azure Storage Account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="580" y="450" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="tfstate" value="Terraform State (Blob Storage)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="100" y="450" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="github" value="GitHub Actions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="100" y="620" width="250" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="endArrow=block" edge="1" parent="1" source="internet" target="frontdoor">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="endArrow=block" edge="1" parent="1" source="frontdoor" target="web">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="endArrow=block" edge="1" parent="1" source="frontdoor" target="api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" style="endArrow=block" edge="1" parent="1" source="api" target="storage">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" style="endArrow=block;dashed=1" edge="1" parent="1" source="github" target="tfstate">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
